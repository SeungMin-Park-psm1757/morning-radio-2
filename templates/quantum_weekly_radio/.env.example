# Existing repo variables
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Weekly quantum settings
WEEKLY_QUANTUM_ENABLED=true
WEEKLY_QUANTUM_TIMEZONE=Asia/Seoul
WEEKLY_QUANTUM_OUTPUT_DIR=output/weekly_quantum
WEEKLY_QUANTUM_STATE_PATH=state/weekly_quantum_run_state.json
WEEKLY_QUANTUM_SITE_CONFIG=config/sites.yaml

# Collection window
WEEKLY_QUANTUM_INITIAL_LOOKBACK_DAYS=8
WEEKLY_QUANTUM_MAX_LIST_ITEMS_PER_SOURCE=80
WEEKLY_QUANTUM_MAX_DETAIL_FETCHES=16
WEEKLY_QUANTUM_MAX_SELECTED_STORIES=12

# Budget
WEEKLY_QUANTUM_BUDGET_MODE=low
WEEKLY_QUANTUM_ENABLE_TTS=true
WEEKLY_QUANTUM_ENABLE_TELEGRAM=true

# Voices
WEEKLY_QUANTUM_HOST_NAME=민준
WEEKLY_QUANTUM_ANALYST_NAME=서연
WEEKLY_QUANTUM_HOST_VOICE=
WEEKLY_QUANTUM_ANALYST_VOICE=
WEEKLY_QUANTUM_TTS_SPEED=1.0
WEEKLY_QUANTUM_TTS_TURN_PAUSE=1.0

# Operations
WEEKLY_QUANTUM_RETRY_COUNT=2
WEEKLY_QUANTUM_REQUEST_TIMEOUT_SECONDS=20
WEEKLY_QUANTUM_HEARTBEAT_URL=
WEEKLY_QUANTUM_ARCHIVE_LIMIT=20
